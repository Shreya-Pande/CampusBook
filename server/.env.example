# Copy this file to .env (project root) and fill in real values.
# See README.md "Environment Variables" section for a description of each.

MONGODB_URI=mongodb://localhost:27017/campusbook?replicaSet=rs0
REDIS_URL=rediss://default:your_upstash_password@your-instance.upstash.io:6379

PORT=5000
NODE_ENV=development

JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

RESEND_API_KEY=re_your_resend_api_key

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

SUPER_ADMIN_EMAIL=superadmin@college.edu
SUPER_ADMIN_PASSWORD=change_this_password

CLIENT_URL=http://localhost:5173
# Optional — set after the first Vercel deploy so CORS also allows the
# production frontend origin. Not required for local development.
CLIENT_URL_PROD=
